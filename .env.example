# Скопируй в .env и заполни
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=halyk_travel
POSTGRES_USER=halyk
POSTGRES_PASSWORD=halyk_secret

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Если поднимаешь бэк ЛОКАЛЬНО (не через Docker) ──────────
DATABASE_URL=postgresql://halyk:halyk_secret@localhost:5432/halyk_travel

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ─── Nuxt (фронт) ─────────────────────────────────────────────
NUXT_PUBLIC_API_URL=http://localhost:8000
